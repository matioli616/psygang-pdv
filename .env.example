# ============================================
# PsyGang Vendas — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ============================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui  # NUNCA expor no client

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (monitoramento de erros — obrigatório em produção)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.us.sentry.io/zzz
# SENTRY_AUTH_TOKEN=seu-token  # opcional: habilita upload de source maps no build
